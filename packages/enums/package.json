{
  "name": "@lactalink/enums",
  "version": "1.0.0",
  "description": "Lactalink shared enumerated types",
  "private": true,
  "author": "Julius Pahama <www.linkedin.com/in/julius-pahama>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./inventory": {
      "types": "./dist/inventory.d.ts",
      "default": "./dist/inventory.js"
    },
    "./notifications": {
      "types": "./dist/notifications.d.ts",
      "default": "./dist/notifications.js"
    },
    "./transactions": {
      "types": "./dist/transactions.d.ts",
      "default": "./dist/transactions.js"
    },
    "./milkbags": {
      "types": "./dist/milkbags.d.ts",
      "default": "./dist/milkbags.js"
    },
    "./identities": {
      "types": "./dist/identities.d.ts",
      "default": "./dist/identities.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "build:init": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint --fix . && prettier --write ."
  },
  "devDependencies": {
    "@lactalink/eslint-config": "workspace:*",
    "@lactalink/typescript-config": "workspace:*"
  }
}
