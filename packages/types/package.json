{
  "name": "@lactalink/types",
  "version": "2.0.0",
  "description": "Lactalink shared types",
  "private": true,
  "author": "Julius Pahama <www.linkedin.com/in/julius-pahama>",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "default": "./dist/auth.js"
    },
    "./api": {
      "types": "./dist/api.d.ts",
      "default": "./dist/api.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    },
    "./supabase": {
      "types": "./dist/supabase-types.d.ts",
      "default": "./dist/supabase-types.js"
    },
    "./collections": {
      "types": "./dist/collections/index.d.ts",
      "default": "./dist/collections/index.js"
    },
    "./payload-generated-types": {
      "types": "./dist/payload-types/generated.d.ts",
      "default": "./dist/payload-types/generated.js"
    },
    "./payload-types": {
      "types": "./dist/payload-types/index.d.ts",
      "default": "./dist/payload-types/index.js"
    },
    "./psgc": {
      "types": "./dist/psgc.d.ts",
      "default": "./dist/psgc.js"
    },
    "./schemas": {
      "types": "./dist/schemas/index.d.ts",
      "default": "./dist/schemas/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    },
    "./database": {
      "types": "./dist/database-types.d.ts",
      "default": "./dist/database-types.js"
    },
    "./geocoding": {
      "types": "./dist/geocoding.d.ts",
      "default": "./dist/geocoding.js"
    }
  },
  "scripts": {
    "build": "tspc",
    "dev": "tspc --watch",
    "dev:safe": "pnpm dev",
    "lint": "eslint .",
    "lint:fix": "eslint --fix . && prettier --write ."
  },
  "devDependencies": {
    "@lactalink/enums": "workspace:*",
    "@lactalink/eslint-config": "workspace:*",
    "@lactalink/typescript-config": "workspace:*",
    "@supabase/supabase-js": "^2.49.4",
    "@types/node": "^22.5.4",
    "payload": "^3.79.0",
    "react-hook-form": "^7.63.0",
    "zod": "^4.1.3"
  },
  "peerDependencies": {
    "@lactalink/enums": "workspace:*",
    "@supabase/supabase-js": "^2.49.4",
    "payload": "^3.79.0",
    "react-hook-form": "^7.63.0",
    "zod": "^4.1.3"
  },
  "peerDependenciesMeta": {
    "payload": {
      "optional": false
    },
    "@supabase/supabase-js": {
      "optional": false
    },
    "@lactalink/enums": {
      "optional": false
    }
  }
}
