{
  "name": "@lactalink/types",
  "version": "1.0.0",
  "description": "Lactalink shared types",
  "private": true,
  "author": "Julius Pahama <www.linkedin.com/in/julius-pahama>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.d.ts",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auth": {
      "types": "./dist/auth.d.ts",
      "default": "./dist/auth.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "default": "./dist/errors.js"
    },
    "./forms": {
      "types": "./dist/forms/index.d.ts",
      "default": "./dist/forms/index.js"
    },
    "./interfaces": {
      "types": "./dist/interfaces/index.d.ts",
      "default": "./dist/interfaces/index.js"
    },
    "./enums": {
      "types": "./dist/enums/index.d.ts",
      "default": "./dist/enums/index.js"
    },
    "./supabase": {
      "types": "./dist/supabase-types.d.ts",
      "default": "./dist/supabase-types.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "build:init": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint --fix . && prettier --write ."
  },
  "devDependencies": {
    "@lactalink/eslint-config": "workspace:*",
    "@lactalink/typescript-config": "workspace:*",
    "@lactalink/enums": "workspace:*",
    "@supabase/supabase-js": "^2.49.4",
    "@types/node": "^22.5.4",
    "payload": "^3.34.0",
    "zod": "^3.25.64"
  },
  "peerDependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "zod": "^3.25.64"
  }
}
