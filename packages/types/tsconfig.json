{
  "extends": "@lactalink/typescript-config",
  "compilerOptions": {
    "baseUrl": ".",
    "outDir": "dist",
    "rootDir": "src",
    "emitDeclarationOnly": true,
    "paths": {
      "@/*": ["./src/*"],
    }
  },
  "include": ["src"],
  "exclude": ["node_modules/**", "dist/**", ".turbo/**", "build/**"]
}
