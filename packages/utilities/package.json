{
  "name": "@lactalink/utilities",
  "version": "1.2.0",
  "description": "Lactalink shared utilities",
  "private": true,
  "author": "Julius Pahama <www.linkedin.com/in/julius-pahama>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./formatters": {
      "types": "./dist/formatters/index.d.ts",
      "default": "./dist/formatters/index.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "default": "./dist/hooks/index.js"
    },
    "./extractors": {
      "types": "./dist/extractors/index.d.ts",
      "default": "./dist/extractors/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "default": "./dist/errors/index.js"
    },
    "./getters": {
      "types": "./dist/getters/index.d.ts",
      "default": "./dist/getters/index.js"
    },
    "./type-guards": {
      "types": "./dist/type-guards/index.d.ts",
      "default": "./dist/type-guards/index.js"
    },
    "./geo-utils": {
      "types": "./dist/geo-utils/index.d.ts",
      "default": "./dist/geo-utils/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "build:init": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint --fix . && prettier --write ."
  },
  "dependencies": {
    "@types/kdbush": "^3.0.5",
    "geolib": "^3.3.4",
    "kdbush": "^4.0.2"
  },
  "devDependencies": {
    "@lactalink/enums": "workspace:*",
    "@lactalink/eslint-config": "workspace:*",
    "@lactalink/types": "workspace:*",
    "@lactalink/typescript-config": "workspace:*",
    "@supabase/supabase-js": "^2.49.4",
    "@types/lodash": "^4.17.17",
    "@types/node": "^22.5.4",
    "@types/react": "^19.0.14",
    "lodash": "^4.17.21",
    "react": "19.0.0"
  },
  "peerDependencies": {
    "@lactalink/enums": "workspace:*",
    "@supabase/supabase-js": "^2.49.4",
    "@types/react": "^19.0.14",
    "lodash": "^4.17.21",
    "react": "19.0.0"
  }
}
