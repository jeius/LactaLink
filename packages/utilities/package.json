{
  "name": "@lactalink/utilities",
  "version": "1.0.0",
  "description": "Lactalink shared utilities",
  "private": true,
  "author": "Julius Pahama <www.linkedin.com/in/julius-pahama>",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./formatString": {
      "types": "./dist/formatString.d.ts",
      "default": "./dist/formatString.js"
    },
    "./hooks": {
      "types": "./dist/hooks/index.d.ts",
      "default": "./dist/hooks/index.js"
    },
    "./errors": {
      "types": "./dist/errors/index.d.ts",
      "default": "./dist/errors/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint .",
    "lint:fix": "eslint --fix . && prettier --write ."
  },
  "devDependencies": {
    "@lactalink/types": "workspace:*",
    "@lactalink/eslint-config": "workspace:*",
    "@lactalink/typescript-config": "workspace:*",
    "@tanstack/react-query": "^5.71.10",
    "@types/node": "^22.5.4",
    "@types/react": "^19.1.2",
    "react": "18.3.1"
  },
  "peerDependencies": {
    "@tanstack/react-query": "^5.71.10"
  }
}
