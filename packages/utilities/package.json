{
  "name": "@lactalink/utilities",
  "version": "1.0.0",
  "description": "Lactalink shared utilities",
  "private": true,
  "author": "Julius Pahama <www.linkedin.com/in/julius-pahama>",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./formatString": {
      "types": "./dist/formatString.d.ts",
      "default": "./dist/formatString.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch"
  },
  "devDependencies": {
    "@lactalink/typescript-config": "workspace:*",
    "@lactalink/types": "workspace:*",
    "@types/node": "^22.5.4"
  }
}
