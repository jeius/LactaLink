{
  "name": "@lactalink/api",
  "version": "2.0.2",
  "description": "Lactalink api client",
  "private": true,
  "author": "Julius Pahama <www.linkedin.com/in/julius-pahama>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    "./v1": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./v1/auth-client": {
      "types": "./dist/auth/AuthClient.d.ts",
      "default": "./dist/auth/AuthClient.js"
    },
    "./v1/client": {
      "types": "./dist/ApiClient.d.ts",
      "default": "./dist/ApiClient.js"
    },
    "./v1/interfaces": {
      "types": "./dist/interfaces/index.d.ts",
      "default": "./dist/interfaces/index.js"
    },
    "./v1/utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    },
    "./v1/services": {
      "types": "./dist/services/index.d.ts",
      "default": "./dist/services/index.js"
    },
    ".": {
      "types": "./dist/v2/index.d.ts",
      "default": "./dist/v2/index.js"
    },
    "./auth-client": {
      "types": "./dist/v2/auth/AuthClient.d.ts",
      "default": "./dist/v2/auth/AuthClient.js"
    },
    "./client": {
      "types": "./dist/v2/ApiClient.d.ts",
      "default": "./dist/v2/ApiClient.js"
    },
    "./interfaces": {
      "types": "./dist/v2/interfaces/index.d.ts",
      "default": "./dist/v2/interfaces/index.js"
    },
    "./utils": {
      "types": "./dist/v2/utils/index.d.ts",
      "default": "./dist/v2/utils/index.js"
    },
    "./services": {
      "types": "./dist/v2/services/index.d.ts",
      "default": "./dist/v2/services/index.js"
    }
  },
  "scripts": {
    "build": "tspc",
    "dev": "tspc --watch",
    "dev:safe": "pnpm dev",
    "lint": "eslint .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@payloadcms/sdk": "^3.79.0",
    "http-status": "^2.1.0",
    "qs-esm": "^7.0.3"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@lactalink/enums": "workspace:*",
    "@lactalink/eslint-config": "workspace:*",
    "@lactalink/form-schemas": "workspace:*",
    "@lactalink/types": "workspace:*",
    "@lactalink/typescript-config": "workspace:*",
    "@lactalink/utilities": "workspace:*",
    "@supabase/supabase-js": "^2.89.0",
    "@types/lodash": "^4.17.17",
    "@types/node": "^22.5.4",
    "@types/react": "^19.1.17",
    "dotenv": "^16.5.0",
    "install": "^0.13.0",
    "lodash": "^4.17.21",
    "npm": "^11.5.2",
    "payload": "^3.79.0",
    "react": "19.1.0",
    "zustand": "^5.0.5"
  },
  "peerDependencies": {
    "@lactalink/enums": "workspace:*",
    "@lactalink/form-schemas": "workspace:*",
    "@lactalink/types": "workspace:*",
    "@lactalink/utilities": "workspace:*",
    "@supabase/supabase-js": "*",
    "@types/react": "*",
    "lodash": "*",
    "payload": "*",
    "react": "*",
    "zustand": "*"
  },
  "peerDependenciesMeta": {
    "@lactalink/enums": {
      "optional": false
    },
    "@lactalink/form-schemas": {
      "optional": false
    },
    "@lactalink/utilities": {
      "optional": false
    },
    "@lactalink/types": {
      "optional": false
    },
    "@supabase/supabase-js": {
      "optional": false
    },
    "lodash": {
      "optional": false
    },
    "payload": {
      "optional": false
    },
    "zustand": {
      "optional": false
    }
  }
}
