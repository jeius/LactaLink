{
  "name": "@lactalink/api",
  "version": "1.0.0",
  "description": "Lactalink api client",
  "private": true,
  "author": "Julius Pahama <www.linkedin.com/in/julius-pahama>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auth-client": {
      "types": "./dist/auth/AuthClient.d.ts",
      "default": "./dist/auth/AuthClient.js"
    },
    "./client": {
      "types": "./dist/ApiClient.d.ts",
      "default": "./dist/ApiClient.js"
    },
    "./interfaces": {
      "types": "./dist/interfaces/index.d.ts",
      "default": "./dist/interfaces/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "default": "./dist/utils/index.js"
    },
    "./services": {
      "types": "./dist/services/index.d.ts",
      "default": "./dist/services/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "build:init": "tsc",
    "lint": "eslint .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "test": "jest --runInBand --passWithNoTests",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "http-status": "^2.1.0",
    "qs": "^6.14.0"
  },
  "devDependencies": {
    "@babel/core": "^7.27.4",
    "@babel/preset-env": "^7.28.0",
    "@lactalink/enums": "workspace:*",
    "@lactalink/eslint-config": "workspace:*",
    "@lactalink/form-schemas": "workspace:*",
    "@lactalink/types": "workspace:*",
    "@lactalink/typescript-config": "workspace:*",
    "@lactalink/utilities": "workspace:*",
    "@supabase/supabase-js": "^2.78.0",
    "@types/lodash": "^4.17.17",
    "@types/node": "^22.5.4",
    "@types/qs": "^6.14.0",
    "@types/react": "^19.1.17",
    "babel-jest": "^30.0.5",
    "dotenv": "^16.5.0",
    "install": "^0.13.0",
    "lodash": "^4.17.21",
    "npm": "^11.5.2",
    "react": "19.1.0",
    "zustand": "^5.0.5"
  },
  "peerDependencies": {
    "@lactalink/enums": "workspace:*",
    "@lactalink/form-schemas": "workspace:*",
    "@lactalink/utilities": "workspace:*",
    "@supabase/supabase-js": "^2.78.0",
    "@types/react": "^19.1.17",
    "lodash": "^4.17.21",
    "react": "19.1.0",
    "zustand": "^5.0.5"
  }
}
