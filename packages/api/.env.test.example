# LactaLink API — Integration Test Environment
#
# PURPOSE
# -------
# This file is loaded by `vitest.config.ts` and `tests/setup.ts` before every
# test run.
#
# REQUIREMENTS BEFORE RUNNING TESTS
# -----------------------------------
# 1. Ensure you have a test database set up and accessible.
# 3. Copy this file to `.env.test`.
# 4. Fill in the values below.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

API_URL=your-api-url

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ---------------------------------------------------------------------------
# Optional (only needed if your tests interact with the database directly)
# ---------------------------------------------------------------------------

# Admin user credentials
ADMIN_EMAIL=your-admin-email
ADMIN_PASSWORD=your-admin-password

# Authenticated user credentials
USER_EMAIL=your-user-email
USER_PASSWORD=your-user-password