{
  "expo": {
    "name": "LactaLink",
    "slug": "lactalink",
    "description": "A breastmilk sharing platform that connects donors, recipients, hospitals, and milk banks for safe and efficient milk distribution.",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "backgroundColor": "#FFF7F7",
    "primaryColor": "#FE828C",
    "scheme": "lactalink",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "platforms": ["ios", "android"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lactalink.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FE828C"
      },
      "package": "com.lactalink.mobile"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#FFCDD1"
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "ee00ec97-b3a9-4e3e-b499-95bb14571879"
      }
    },
    "owner": "lactalink",
    "runtimeVersion": {
      "policy": "sdkVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ee00ec97-b3a9-4e3e-b499-95bb14571879"
    }
  }
}
