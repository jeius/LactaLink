{
  "cli": {
    "version": ">= 16.3.1",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "monorepo": {
      "pnpm": "9.15.7",
      "node": "22.14.0",
      "env": {
        "EXPO_USE_FAST_RESOLVER": "true",
        "EXPO_THEME": "light"
      }
    },
    "development": {
      "extends": "monorepo",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "environment": "development",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:3000",
        "EXPO_PUBLIC_ENVIRONMENT": "development"
      }
    },
    "preview": {
      "extends": "monorepo",
      "distribution": "internal",
      "channel": "preview",
      "environment": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://lacta-link-web.vercel.app"
      }
    },
    "production": {
      "extends": "monorepo",
      "autoIncrement": true,
      "channel": "production",
      "environment": "production",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://www.lactalink.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
