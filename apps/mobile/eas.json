{
  "cli": {
    "version": ">= 16.3.1",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false,
    "requireCommit": true
  },
  "build": {
    "monorepo": {
      "pnpm": "9.15.7",
      "node": "22.14.0",
      "cache": {
        "key": "turbo",
        "paths": ["../../.turbo/cache"]
      },
      "env": {
        "EXPO_USE_FAST_RESOLVER": "true"
      }
    },
    "development": {
      "extends": "monorepo",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "API_URL": "http://localhost:3000"
      }
    },
    "preview": {
      "extends": "monorepo",
      "distribution": "internal",
      "channel": "preview",
      "android": {
        "buildType": "apk"
      }
    },
    "production": {
      "extends": "monorepo",
      "autoIncrement": true,
      "channel": "production",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "API_URL": "https://www.lactalink.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
