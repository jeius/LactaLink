{
  "cli": {
    "version": ">= 16.24.1",
    "appVersionSource": "remote",
    "promptToConfigurePushNotifications": false
  },
  "build": {
    "monorepo": {
      "node": "24.13.1",
      "pnpm": "10.29.2",
      "env": {
        "EXPO_USE_FAST_RESOLVER": "true",
        "ANDROID_MAPS_API_KEY": "$ANDROID_MAPS_API_KEY",
        "IOS_MAPS_API_KEY": "$IOS_MAPS_API_KEY"
      }
    },
    "development": {
      "extends": "monorepo",
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "environment": "development",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:3000",
        "EXPO_PUBLIC_ENVIRONMENT": "development",
        "NODE_ENV": "development"
      }
    },
    "preview": {
      "extends": "monorepo",
      "distribution": "internal",
      "channel": "preview",
      "environment": "preview",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://vercel.dev.lactalink.com",
        "NODE_ENV": "production"
      }
    },
    "production": {
      "extends": "monorepo",
      "autoIncrement": true,
      "channel": "production",
      "environment": "production",
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "env": {
        "EXPO_PUBLIC_API_URL": "https://vercel.dev.lactalink.com"
      }
    }
  },
  "submit": {
    "production": {}
  }
}
