{
  "name": "@lactalink/mobile",
  "main": "entry.js",
  "description": "Mobile platform of the LactaLink app.",
  "author": "Julius Pahama <www.linkedin.com/in/julius-pahama>",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "expo start --dev-client -c",
    "android": "DARK_MODE=media expo start --android",
    "ios": "DARK_MODE=media expo start --ios",
    "build": "expo export --output-dir ./build --platform all",
    "build:deps": "pnpm -w run build:packages",
    "build:android-dev": "eas build:dev --platform android --profile development",
    "build:ios-dev": "eas build:dev --platform ios --profile development",
    "preview:android": "eas build --platform android --profile preview",
    "preview:update": "eas update --channel preview --branch preview-update --platform android --message \"Updated preview build\" --non-interactive",
    "lint": "eslint --ext js,ts,tsx .",
    "lint:fix": "eslint --ext .js,.ts,.tsx --fix . && prettier --write .",
    "eas-build-pre-install": "pnpm install && pnpm run build:deps",
    "postinstall": "patch-package"
  },
