{
  "name": "@lactalink/mobile",
  "main": "entry.js",
  "description": "Mobile platform of the LactaLink app.",
  "author": "Julius Pahama <www.linkedin.com/in/julius-pahama>",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "expo start --dev-client -c",
    "android": "DARK_MODE=media expo start --android",
    "ios": "DARK_MODE=media expo start --ios",
    "build": "expo export --output-dir ./build --platform all",
    "build:android": "eas build:dev --platform android --profile development",
    "build:ios": "eas build:dev --platform ios --profile development",
    "lint": "eslint --ext js,ts,tsx .",
    "lint:fix": "eslint --ext .js,.ts,.tsx --fix . && prettier --write .",
    "eas-build-pre-install": "echo node-linker=hoisted >> ../../.npmrc"
  },
  "dependencies": {
    "@expo/html-elements": "^0.4.2",
    "@gluestack-ui/button": "^1.0.14",
    "@gluestack-ui/divider": "^0.1.10",
    "@gluestack-ui/form-control": "^0.1.19",
    "@gluestack-ui/icon": "^0.1.27",
    "@gluestack-ui/image": "^0.1.17",
    "@gluestack-ui/input": "^0.1.38",
    "@gluestack-ui/nativewind-utils": "^1.0.26",
    "@gluestack-ui/overlay": "^0.1.22",
    "@gluestack-ui/spinner": "^0.1.15",
    "@gluestack-ui/toast": "^1.0.9",
    "@hookform/resolvers": "^5.0.1",
    "@lactalink/utilities": "workspace:*",
    "@legendapp/motion": "^2.4.0",
    "@react-native-community/netinfo": "^11.4.1",
    "@react-native-google-signin/google-signin": "^13.2.0",
    "@react-native/metro-config": "^0.78.0",
    "@rnx-kit/metro-config": "^2.0.1",
    "@rnx-kit/metro-resolver-symlinks": "^0.2.1",
    "@supabase/supabase-js": "^2.49.4",
    "@tanstack/react-query": "^5.71.10",
    "babel-plugin-dotenv-import": "^3.0.1",
    "babel-plugin-module-resolver": "^5.0.2",
    "expo": "^52.0.46",
    "expo-asset": "~11.0.4",
    "expo-constants": "~17.0.8",
    "expo-crypto": "~14.0.2",
    "expo-dev-client": "~5.0.19",
    "expo-font": "~13.0.4",
    "expo-linear-gradient": "~14.0.2",
    "expo-linking": "~7.0.3",
    "expo-router": "~4.0.20",
    "expo-splash-screen": "~0.29.24",
    "expo-status-bar": "~2.0.1",
    "expo-system-ui": "~4.0.9",
    "expo-updates": "~0.27.4",
    "lucide-react-native": "^0.503.0",
    "nativewind": "^4.1.23",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "^7.56.1",
    "react-native": "0.76.9",
    "react-native-css-interop": "^0.1.22",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-mmkv": "^3.2.0",
    "react-native-otp-entry": "^1.8.4",
    "react-native-reanimated": "~3.16.7",
    "react-native-reanimated-carousel": "^4.0.2",
    "react-native-safe-area-context": "4.12.0",
    "react-native-screens": "~4.4.0",
    "react-native-svg": "15.8.0",
    "react-native-svg-transformer": "^1.5.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "~0.19.6",
    "tailwindcss": "^3.4.17",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@lactalink/eslint-config": "workspace:*",
    "@lactalink/types": "workspace:*",
    "@lactalink/typescript-config": "workspace:*",
    "@react-native-community/cli": "^18.0.0",
    "@types/jest": "^29.5.14",
    "@types/react": "~18.3.12",
    "jscodeshift": "0.15.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "listUnknownPackages": false
      }
    }
  },
  "jest": {
    "setupFiles": [
      "./setupJest.js"
    ]
  }
}
