{
  "name": "@lactalink/web",
  "version": "1.0.0",
  "description": "A blank template to get started with Payload 3.0",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "shx rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "devsafe": "shx rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types && shx cp src/lib/types/payload-types.ts ../../packages/types/src/payload-types.ts",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation next lint",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation next lint --fix && prettier --write .",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start"
  },
  "dependencies": {
    "@payloadcms/db-postgres": "latest",
    "@payloadcms/next": "latest",
    "@payloadcms/plugin-nested-docs": "latest",
    "@payloadcms/plugin-search": "latest",
    "@payloadcms/richtext-lexical": "latest",
    "@payloadcms/storage-s3": "latest",
    "@payloadcms/ui": "latest",
    "@radix-ui/react-slot": "^1.1.2",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.49.4",
    "@tailwindcss/postcss": "^4.1.3",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/react-query": "^5.71.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "google-auth-library": "^9.15.1",
    "graphql": "^16.8.1",
    "http-status": "^2.1.0",
    "jose": "^6.0.10",
    "lucide-react": "^0.487.0",
    "next": "^15.2.3",
    "payload": "latest",
    "payload-auth-plugin": "^0.6.4",
    "postcss": "^8.5.3",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "sharp": "0.32.6",
    "tailwind-merge": "^3.1.0",
    "tailwindcss": "^4.1.3",
    "tw-animate-css": "^1.2.5"
  },
  "devDependencies": {
    "@lactalink/eslint-config": "workspace:*",
    "@lactalink/types": "workspace:*",
    "@lactalink/typescript-config": "workspace:*",
    "@lactalink/utilities": "workspace:*",
    "@svgr/webpack": "^8.1.0",
    "@tanstack/react-query-devtools": "^5.74.4",
    "@types/node": "^22.5.4",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "shx": "^0.4.0"
  }
}
