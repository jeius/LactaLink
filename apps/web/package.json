{
  "name": "@lactalink/web",
  "version": "1.0.0",
  "description": "Backend of the LactaLink mobile app, and possible web platform soon.",
  "author": "Julius Pahama <www.linkedin.com/in/julius-pahama>",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "cross-env NODE_OPTIONS=--no-deprecation next build",
    "build:safe": "shx rm -rf .next && pnpm run build",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev",
    "dev:safe": "shx rm -rf .next && cross-env NODE_OPTIONS=--no-deprecation next dev",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:schema": "cross-env NODE_OPTIONS=--no-deprecation payload generate:db-schema",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "lint": "cross-env NODE_OPTIONS=--no-deprecation eslint . --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "cross-env NODE_OPTIONS=--no-deprecation eslint . --fix",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start"
  },
  "dependencies": {
    "@googlemaps/routing": "^2.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@lactalink/api": "workspace:*",
    "@lactalink/enums": "workspace:*",
    "@lactalink/form-schemas": "workspace:*",
    "@lactalink/utilities": "workspace:*",
    "@payloadcms/db-postgres": "3.62.0",
    "@payloadcms/email-resend": "3.62.0",
    "@payloadcms/next": "3.62.0",
    "@payloadcms/plugin-nested-docs": "3.62.0",
    "@payloadcms/plugin-search": "3.62.0",
    "@payloadcms/richtext-lexical": "3.62.0",
    "@payloadcms/storage-s3": "3.62.0",
    "@payloadcms/ui": "3.62.0",
    "@radix-ui/react-label": "^2.1.4",
    "@radix-ui/react-scroll-area": "^1.2.8",
    "@radix-ui/react-slot": "^1.1.2",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.89.0",
    "@tailwindcss/postcss": "^4.1.16",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.80.7",
    "blurhash": "^2.0.5",
    "canvas": "^3.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "encoding": "^0.1.13",
    "face-api.js": "^0.22.2",
    "graphql": "^16.8.1",
    "http-status": "^2.1.0",
    "input-otp": "^1.4.2",
    "lodash": "^4.17.21",
    "lucide-react": "^0.548.0",
    "next": "15.5.9",
    "next-themes": "^0.4.6",
    "payload": "3.62.0",
    "pino": "^9.9.5",
    "postcss": "^8.5.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.60.0",
    "sharp": "0.34.4",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.16",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.12",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@lactalink/eslint-config": "workspace:*",
    "@lactalink/types": "workspace:*",
    "@lactalink/typescript-config": "workspace:*",
    "@svgr/webpack": "^8.1.0",
    "@tanstack/react-query-devtools": "^5.80.7",
    "@types/lodash": "^4.17.17",
    "@types/node": "^22.5.4",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "pino-pretty": "^13.1.1"
  }
}
