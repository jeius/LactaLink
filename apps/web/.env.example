# ====================================================================================================
# LactaLink Web - Environment Variables Template
# ====================================================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env files to version control
# ====================================================================================================

# ====================================================================================================
# Payload CMS
# ====================================================================================================
PAYLOAD_SECRET=your-payload-secret-key-minimum-32-characters

# ====================================================================================================
# Database
# ====================================================================================================
DATABASE_URI=postgresql://user:password@host:port/database?sslmode=require

# ====================================================================================================
# Google Services
# ====================================================================================================
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CLOUD_VISION_API_KEY=your-google-cloud-vision-api-key
GOOGLE_ROUTES_API_KEY=your-google-routes-api-key

# ====================================================================================================
# S3 / Supabase Storage (for file uploads)
# ====================================================================================================
S3_BUCKET_IMAGES=lactalink-images
S3_BUCKET_MILK_BAG_IMAGES=lactalink-milk-bag-images
S3_BUCKET_ID_IMAGES=lactalink-id-images
S3_BUCKET_MESSAGE_MEDIA=lactalink-message-media
S3_BUCKET_MEDIA=lactalink-media
S3_BUCKET_FILES=lactalink-files
S3_BUCKET_AVATARS=lactalink-avatars

S3_ACCESS_KEY_ID=your-s3-access-key-id
S3_SECRET_ACCESS_KEY=your-s3-secret-access-key
S3_REGION=us-east-1
S3_ENDPOINT=https://your-project.supabase.co/storage/v1/s3

# ====================================================================================================
# External APIs
# ====================================================================================================
PSGC_API_URL=https://psgc.gitlab.io/api
RESEND_API_KEY=re_your-resend-api-key

# ====================================================================================================
# Supabase (Public keys - safe to expose to client)
# ====================================================================================================
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ====================================================================================================
# Application URLs
# ====================================================================================================
# For local development
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# For production (update with your actual domain), ignore this if deploying to Coolify
# NEXT_PUBLIC_SERVER_URL=https://yourdomain.com

# ====================================================================================================
# Notes:
# ====================================================================================================
# 1. Variables starting with NEXT_PUBLIC_ are embedded in the client bundle
#    They MUST be set at build time (as Docker build args)
#
# 2. All other variables should be set at runtime (as environment variables)
#
# 3. For Docker builds, ALL variables must be passed as build args
#
# 4. For Coolify deployment, set variables in the Coolify dashboard:
#    - Set all variables as Build Arguments (for build time)
#    - Enable Docker Build Secrets
#
# 5. Generate secure secrets:
#    - PAYLOAD_SECRET: openssl rand -base64 32
#
# ====================================================================================================
