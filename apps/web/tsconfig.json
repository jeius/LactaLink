{
  "extends": "@lactalink/typescript-config/next",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "react": ["./node_modules/@types/react"],
      "@payload-config": ["./src/payload.config.ts"],
      "@db/*": ["./src/lib/db/*"],
      "@lactalink/form-schemas": ["./src/lib/types/formSchemas.ts"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", ".next/types/**/*.ts", "next.config.mjs"]
}
