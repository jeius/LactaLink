# LactaLink — Integration Test Environment
#
# PURPOSE
# -------
# This file is loaded by `vitest.config.ts` and `tests/setup.ts` before every
# test run.  It points Payload at a **dedicated test database** that is separate
# from your development and production databases so tests can freely create and
# delete records without risk to real data.
#
# REQUIREMENTS BEFORE RUNNING TESTS
# -----------------------------------
# 1. Create a dedicated PostgreSQL database (e.g. `lactalink_test`) on your
#    Supabase project (or a local Postgres instance).
# 2. Run migrations against that database once:
#
#      DATABASE_URI="<test-db-url>" pnpm payload migrate
#
#    This creates the full schema (tables, enums, indexes, views) that Payload
#    and the tests expect.
# 3. Copy this file to `.env.test` (it is already named `.env.test` in the
#    repo; do NOT commit real credentials).
# 4. Fill in the values below.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------

# Full PostgreSQL connection string for the TEST database.
# Must be a separate DB from development/production!
DATABASE_URI=postgresql://postgres:<password>@<host>:5432/lactalink_test?sslmode=require

# Payload CMS secret — can be any 32-char string for tests.
PAYLOAD_SECRET=test-secret-at-least-32-chars-long!

# Base URL used by Payload for server-side URLs in the admin panel.
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Stub values — these services are NOT used during tests but Payload config
# will still read the env vars on startup.  Fake values prevent startup errors.
# ---------------------------------------------------------------------------

# S3 / Supabase Storage (not called by tests — no file uploads)
S3_BUCKET_IMAGES=test-bucket
S3_BUCKET_MILK_BAG_IMAGES=test-bucket
S3_BUCKET_ID_IMAGES=test-bucket
S3_BUCKET_MESSAGE_MEDIA=test-bucket
S3_BUCKET_MEDIA=test-bucket
S3_BUCKET_FILES=test-bucket
S3_BUCKET_AVATARS=test-bucket
S3_ACCESS_KEY_ID=test-access-key
S3_SECRET_ACCESS_KEY=test-secret-key
S3_REGION=us-east-1
S3_ENDPOINT=https://test.supabase.co/storage/v1/s3

# Email (Resend) — no emails are sent during tests
RESEND_API_KEY=re_test_stub_key

# Google APIs — not used in tests
GOOGLE_CLIENT_ID=test-client-id
GOOGLE_CLIENT_SECRET=test-client-secret
GOOGLE_CLOUD_VISION_API_KEY=test-vision-key
GOOGLE_ROUTES_API_KEY=test-routes-key

# Supabase public vars — not used in tests (no Supabase Auth calls)
NEXT_PUBLIC_SUPABASE_URL=https://test.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=test-anon-key

# PSGC geographic data API
PSGC_API_URL=https://psgc.gitlab.io/api
