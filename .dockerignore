# ====================================================================================================
# LactaLink - Docker Ignore Configuration
# ====================================================================================================
# Excludes unnecessary files from Docker build context for faster builds and smaller images
# ====================================================================================================

# Git
.git
.gitignore
.gitattributes
.github

# Dependencies
node_modules
**/node_modules
.pnpm-store

# Build outputs
**/dist
**/.next
!apps/web/.next
**/build
**/.expo
**/.turbo
**/coverage

# Cache directories
.cache
**/.cache
.turbo
**/.eslintcache

# IDE & Editor
.vscode
.idea
*.swp
*.swo
*~
.DS_Store
*.log

# Environment files (use build args instead)
.env
.env.local
.env.development
.env.production
.env.*.local
**/.env
**/.env.local
**/.env.development
**/.env.production

# Testing
**/coverage
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx
**/__tests__
**/__mocks__

# Documentation
*.md
!README.md
docs/
LICENSE

# Mobile app (not needed for web deployment)
apps/mobile/

# Miscellaneous
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
.pnpm-debug.log

# OS
.DS_Store
Thumbs.db
desktop.ini

# Docker
Dockerfile*
.dockerignore
docker-compose*.yml

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.swp

# TypeScript
*.tsbuildinfo

# Database
database/
*.sql

# Scripts
scripts/
clean-monorepo.js

# Patches
patches/
