{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "test": {
      "dependsOn": ["build"],
      "inputs": ["**/*.{ts,tsx,js,jsx}"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.development", ".env.production"],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        "build/**",
        "node_modules/.cache/metro/**"
      ],
      "env": [
        "PAYLOAD_SECRET",
        "DATABASE_URI",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "GOOGLE_CLOUD_VISION_API_KEY",
        "GOOGLE_ROUTES_API_KEY",
        "S3_BUCKET_IMAGES",
        "S3_BUCKET_MILK_BAG_IMAGES",
        "S3_BUCKET_ID_IMAGES",
        "S3_BUCKET_MESSAGE_MEDIA",
        "S3_BUCKET_MEDIA",
        "S3_BUCKET_FILES",
        "S3_BUCKET_AVATARS",
        "S3_ACCESS_KEY_ID",
        "S3_SECRET_ACCESS_KEY",
        "S3_REGION",
        "S3_ENDPOINT",
        "PSGC_API_URL",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY",
        "RESEND_API_KEY"
      ]
    },
    "dev": {
      "cache": false,
      "dependsOn": ["@lactalink/web#generate:schema", "@lactalink/web#generate:types"],
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"]
    },
    "@lactalink/web#generate:types": {
      "inputs": [
        "src/collections/**/*",
        "src/blocks/**/*",
        "src/globals/**/*",
        "src/jobs/**/*",
        "src/hooks/collections/**/*",
        "src/fields/**/*",
        "src/lib/constants/**/*",
        "src/lib/plugins/**/*",
        "src/payload.config.ts"
      ],
      "outputs": [
        "src/lib/types/payload-types.ts",
        "../../packages/types/src/payload-types/generated.ts"
      ]
    },
    "@lactalink/web#generate:importmap": {
      "inputs": ["src/**/*"],
      "outputs": ["src/app/*/admin/importMap.js"]
    },
    "@lactalink/web#generate:schema": {
      "inputs": [
        "src/collections/**/*",
        "src/hooks/collections/**/*",
        "src/fields/**/*",
        "src/lib/constants/**/*",
        "src/payload.config.ts"
      ],
      "outputs": ["src/lib/db/drizzle/schema/payload-schema.ts"]
    }
  }
}
