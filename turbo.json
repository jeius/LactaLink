{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "test": {
      "dependsOn": ["build"],
      "inputs": ["**/*.{ts,tsx,js,jsx}"]
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env", ".env.development", ".env.production"],
      "outputs": [
        "dist/**",
        ".next/**",
        "!.next/cache/**",
        "build/**",
        "node_modules/.cache/metro/**"
      ],
      "env": [
        "PAYLOAD_SECRET",
        "DATABASE_URI",
        "GOOGLE_CLIENT_ID",
        "GOOGLE_CLIENT_SECRET",
        "S3_BUCKET_IMAGES",
        "S3_BUCKET_MEDIA",
        "S3_BUCKET_FILES",
        "S3_BUCKET_AVATARS",
        "S3_ACCESS_KEY_ID",
        "S3_SECRET_ACCESS_KEY",
        "S3_REGION",
        "S3_ENDPOINT",
        "PSGC_API_URL",
        "NEXT_PUBLIC_SUPABASE_URL",
        "NEXT_PUBLIC_SUPABASE_ANON_KEY"
      ]
    },
    "dev": {
      "cache": false,
      "dependsOn": ["@lactalink/web#generate:types", "@lactalink/web#generate:schema"],
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "lint:fix": {
      "dependsOn": ["^lint:fix"]
    },
    "@lactalink/web#generate:types": {
      "inputs": [
        "src/collections/**/*",
        "src/hooks/collections/**/*",
        "src/fields/**/*",
        "src/lib/constants/**/*"
      ],
      "outputs": ["src/lib/types/payload-types.ts", "../../packages/types/src/payload-types.ts"]
    },
    "@lactalink/web#generate:importmap": {
      "inputs": ["src/**/*"],
      "outputs": ["src/app/*/admin/importMap.js"]
    },
    "@lactalink/web#generate:schema": {
      "inputs": [
        "src/collections/**/*",
        "src/hooks/collections/**/*",
        "src/fields/**/*",
        "src/lib/constants/**/*"
      ],
      "outputs": ["src/lib/db/**/*"]
    },
    "build:android-dev": {
      "dependsOn": ["^build", "@lactalink/mobile#build:android-dev"],
      "cache": false
    },
    "build:ios-dev": {
      "dependsOn": ["^build", "@lactalink/mobile#build:ios-dev"],
      "cache": false
    },
    "build:init": {
      "dependsOn": ["^build:init"],
      "cache": false
    },
    "preview:android": {
      "dependsOn": ["^build", "@lactalink/mobile#preview:android"],
      "cache": false
    }
  }
}
