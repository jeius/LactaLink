# ====================================================================================================
# LactaLink Web - GitHub Actions Docker Build Workflow (OPTIONAL)
# ====================================================================================================
# This workflow automatically builds and pushes Docker images to a container registry
# Uncomment and configure if you want automated builds on GitHub
# ====================================================================================================

name: Build and Push Docker Image

on:
  push:
    branches:
      - main
      - development
    tags:
      - 'v*.*.*'
  pull_request:
    branches:
      - main

env:
  REGISTRY: ghcr.io
  IMAGE_NAME: ${{ github.repository }}

jobs:
  build-and-push:
    runs-on: ubuntu-latest
    permissions:
      contents: read
      packages: write

    steps:
      - name: Checkout repository
        uses: actions/checkout@v4

      - name: Set up Docker Buildx
        uses: docker/setup-buildx-action@v3

      - name: Log in to Container Registry
        uses: docker/login-action@v3
        with:
          registry: ${{ env.REGISTRY }}
          username: ${{ github.actor }}
          password: ${{ secrets.GITHUB_TOKEN }}

      - name: Extract metadata
        id: meta
        uses: docker/metadata-action@v5
        with:
          images: ${{ env.REGISTRY }}/${{ env.IMAGE_NAME }}
          tags: |
            type=ref,event=branch
            type=ref,event=pr
            type=semver,pattern={{version}}
            type=semver,pattern={{major}}.{{minor}}
            type=sha,prefix={{branch}}-

      - name: Build and push Docker image
        uses: docker/build-push-action@v5
        with:
          context: .
          file: ./apps/web/Dockerfile
          push: true
          tags: ${{ steps.meta.outputs.tags }}
          labels: ${{ steps.meta.outputs.labels }}
          cache-from: type=gha
          cache-to: type=gha,mode=max
          build-args: |
            PAYLOAD_SECRET=${{ secrets.PAYLOAD_SECRET }}
            DATABASE_URI=${{ secrets.DATABASE_URI }}
            GOOGLE_CLIENT_ID=${{ secrets.GOOGLE_CLIENT_ID }}
            GOOGLE_CLIENT_SECRET=${{ secrets.GOOGLE_CLIENT_SECRET }}
            GOOGLE_CLOUD_VISION_API_KEY=${{ secrets.GOOGLE_CLOUD_VISION_API_KEY }}
            GOOGLE_ROUTES_API_KEY=${{ secrets.GOOGLE_ROUTES_API_KEY }}
            S3_BUCKET_IMAGES=${{ secrets.S3_BUCKET_IMAGES }}
            S3_BUCKET_MILK_BAG_IMAGES=${{ secrets.S3_BUCKET_MILK_BAG_IMAGES }}
            S3_BUCKET_ID_IMAGES=${{ secrets.S3_BUCKET_ID_IMAGES }}
            S3_BUCKET_MESSAGE_MEDIA=${{ secrets.S3_BUCKET_MESSAGE_MEDIA }}
            S3_BUCKET_MEDIA=${{ secrets.S3_BUCKET_MEDIA }}
            S3_BUCKET_FILES=${{ secrets.S3_BUCKET_FILES }}
            S3_BUCKET_AVATARS=${{ secrets.S3_BUCKET_AVATARS }}
            S3_ACCESS_KEY_ID=${{ secrets.S3_ACCESS_KEY_ID }}
            S3_SECRET_ACCESS_KEY=${{ secrets.S3_SECRET_ACCESS_KEY }}
            S3_REGION=${{ secrets.S3_REGION }}
            S3_ENDPOINT=${{ secrets.S3_ENDPOINT }}
            PSGC_API_URL=${{ secrets.PSGC_API_URL }}
            NEXT_PUBLIC_SUPABASE_URL=${{ secrets.NEXT_PUBLIC_SUPABASE_URL }}
            NEXT_PUBLIC_SUPABASE_ANON_KEY=${{ secrets.NEXT_PUBLIC_SUPABASE_ANON_KEY }}
            RESEND_API_KEY=${{ secrets.RESEND_API_KEY }}

# ====================================================================================================
# Setup Instructions:
# ====================================================================================================
# 1. Go to your GitHub repository settings
# 2. Navigate to Secrets and Variables > Actions
# 3. Add all environment variables as repository secrets
# 4. Enable GitHub Actions in your repository
# 5. Push to main/development branch to trigger the workflow
#
# The built image will be available at:
# ghcr.io/your-username/lactalink:tag
# ====================================================================================================
