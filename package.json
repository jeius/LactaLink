{
  "private": true,
  "name": "lactalink",
  "author": "Julius Pahama <www.linkedin.com/in/julius-pahama>",
  "scripts": {
    "build": "turbo build",
    "build:api": "turbo build --filter=\"{./packages/api}...\"",
    "build:enums": "turbo build --filter=\"{./packages/enums}...\"",
    "build:mobile": "turbo build --filter=\"...{./apps/mobile}\"",
    "build:web": "turbo build --filter=\"{./apps/web}...\"",
    "build:types": "turbo build --filter=\"{./packages/types}...\"",
    "build:utils": "turbo build --filter=\"{./packages/utilities}...\"",
    "build:packages": "turbo build --filter=\"{./packages/*}...\"",
    "dev": "turbo dev",
    "dev:mobile": "turbo dev --filter=\"{./apps/mobile}...\"",
    "dev:web": "turbo dev --filter=\"{./apps/web}...\"",
    "dev:packages": "turbo dev --filter=\"{./packages/*}...\"",
    "generate:types": "turbo @lactalink/web#generate:types ",
    "generate:importmap": "turbo @lactalink/web#generate:importmap",
    "generate:schema": "turbo @lactalink/web#generate:schema",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "test": "turbo test",
    "clean:all": "node clean-monorepo.js",
    "refresh": "pnpm clean:all && pnpm install && pnpm run build:packages"
  },
  "devDependencies": {
    "glob": "^11.0.3",
    "patch-package": "^8.0.0",
    "postinstall-postinstall": "^2.1.0",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.13",
    "shx": "^0.4.0",
    "turbo": "^2.5.4",
    "typescript": "^5.8.3"
  },
  "packageManager": "pnpm@9.15.7",
  "engines": {
    "node": "^22.14.0",
    "pnpm": "^9.15.7"
  }
}
